{
  "version": 1,
  "minExtensionVersion": "1.0.0",
  "updatedAt": "2026-03-29T12:00:00Z",
  "patterns": {
    "pageRecognition": {
      "hasPRContent": {
        "regex": "id=\"js-issues-search\"",
        "flags": "i"
      },
      "knownSelectors": {
        "regex": "js-navigation-container",
        "flags": "i"
      },
      "emptyState": {
        "regex": "blankslate",
        "flags": "i"
      },
      "noResults": {
        "regex": "No results matched your search",
        "flags": "i"
      }
    },
    "prLink": [
      {
        "regex": "<a[^>]*href=\"([^\"]*\\/pull\\/\\d+)\"[^>]*class=\"[^\"]*(?:markdown-title|js-navigation-open|Link--primary)[^\"]*\"[^>]*>([^<]+)<\\/a>",
        "flags": "i",
        "captureGroups": {
          "url": 1,
          "title": 2
        }
      }
    ],
    "prNumber": [
      {
        "regex": "<span[^>]*class=\"[^\"]*opened-by[^\"]*\"[^>]*>\\s*#(\\d+)",
        "flags": "i",
        "captureGroups": {
          "number": 1
        }
      }
    ],
    "repoName": {
      "regex": "data-hovercard-type=\"repository\"[^>]*>([^<]+)<\\/a>",
      "flags": "i",
      "captureGroups": {
        "name": 1
      }
    }
  }
}
